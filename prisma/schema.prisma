generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

enum Plan {
  FREE
  PREMIUM
}

enum UserRole {
  USER
  ADMIN
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  weight        Int?      // Waga użytkownika w kg - ważna dla opinii o oponach/dętkach (ciśnienie vs waga)
  role          UserRole  @default(USER)
  plan          Plan      @default(FREE)
  planExpiresAt DateTime? // Data wygaśnięcia planu Premium
  bio           String?   @db.Text // Krótki opis na profilu publicznym
  profileSlug    String?   @unique  // URL-friendly identyfikator profilu publicznego
  lastStravaSync     DateTime?          // Ostatnia synchronizacja dystansów ze Strava
  partsDisplayOrder  Json?              // Kolejność kategorii i części w akordeonach
  unitPreference     UnitPreference     @default(METRIC) // Preferowany system jednostek
  reputationBonus    Int                @default(0)       // Bonus reputacji ustawiany przez admina (do testów)
  accounts       Account[]
  sessions       Session[]
  bikes          Bike[]
  notifications  Notification[]
  partReviews    PartReview[]
  bikeComments   BikeComment[]
  commentReports CommentReport[]
  reviewReports  ReviewReport[]
  bikeLikes      BikeLike[]
  commentLikes   CommentLike[]
  reviewLikes    ReviewLike[]
  storedParts       StoredPart[]
  customStoredParts CustomStoredPart[]
  emailVerificationTokens EmailVerificationToken[]

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String? @db.Text
  refresh_token     String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BikeType {
  ROAD
  GRAVEL
  MTB
  OTHER
  TRAINER
}

enum SyncStatus {
  synced
  syncing
  error
}

enum PartType {
  // Rama i widelec
  FRAME
  FORK
  SUSPENSION_FORK

  // Stery i suport
  HEADSET
  BOTTOM_BRACKET

  // Napęd
  CRANKSET
  CHAIN
  CASSETTE
  DERAILLEUR_FRONT
  DERAILLEUR_REAR
  SHIFTERS
  PEDALS
  CLEATS
  SHIFT_CABLES

  // Hamulce
  PADS_FRONT
  PADS_REAR
  DISC_FRONT
  DISC_REAR
  BRAKE_CALIPER_FRONT
  BRAKE_CALIPER_REAR
  BRAKE_CABLES
  BRAKE_FLUID

  // Koła
  HUBS
  RIMS
  SPOKES
  TIRE_FRONT
  TIRE_REAR
  INNER_TUBE_FRONT
  INNER_TUBE_REAR
  TUBELESS_SEALANT_FRONT
  TUBELESS_SEALANT_REAR

  // Kierownica i cockpit
  STEM
  HANDLEBAR
  HANDLEBAR_TAPE
  GRIPS

  // Siodło i sztyca
  SADDLE
  SEATPOST
  SUSPENSION_SEATPOST
  DROPPER_POST

  // Akcesoria
  FENDER_FRONT
  FENDER_REAR
  KICKSTAND
  RACK
  BAG_SADDLE
  BAG_FRAME
  BOTTLE_CAGE
  LIGHT_FRONT
  LIGHT_REAR
  BELL
  COMPUTER

  // Inne
  LUBRICANT

  // Przestarzałe (zachowane dla kompatybilności z DB)
  TUBELESS_SEALANT
  CHAINRING_1X
  BRAKES
  BRAKE_LEVERS

  // E-bike
  MOTOR
  BATTERY
  CONTROLLER
}

enum ServiceType {
  CHAIN_LUBE
  CHAIN_REPLACE
  SEALANT_FRONT
  SEALANT_REAR
}

enum MaintenanceType {
  TIRE_PRESSURE
  BIDON_WASH
  BIKE_WASH
  DRIVETRAIN_CLEAN
  CABLE_CHECK
  SPOKE_CHECK
  BOLT_CHECK
  TIRE_CONDITION
}

model MaintenanceLog {
  id        String          @id @default(cuid())
  bikeId    String
  type      MaintenanceType
  kmAtTime  Int
  notes     String?

  bike      Bike            @relation(fields: [bikeId], references: [id], onDelete: Cascade)

  createdAt DateTime        @default(now())

  @@index([bikeId, type, createdAt])
}

model CustomMaintenanceTask {
  id           String   @id @default(cuid())
  bikeId       String
  name         String
  icon         String   @default("Wrench")
  intervalKm   Int?
  intervalDays Int?
  createdAt    DateTime @default(now())

  bike Bike                   @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  logs CustomMaintenanceLog[]

  @@index([bikeId])
}

model CustomMaintenanceLog {
  id        String   @id @default(cuid())
  taskId    String
  bikeId    String
  kmAtTime  Int
  notes     String?
  createdAt DateTime @default(now())

  task CustomMaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  bike Bike                  @relation(fields: [bikeId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model Bike {
  id           String   @id @default(cuid())
  userId       String
  stravaGearId String?  @unique // ID sprzętu ze Strava - dla wykrywania duplikatów
  brand        String?
  model        String?
  year         Int?
  type         BikeType
  description  String?
  isElectric   Boolean  @default(false)
  totalKm      Int      @default(0)
  isPublic     Boolean  @default(false)  // Czy rower jest widoczny publicznie
  slug         String?  @unique          // URL-friendly identyfikator dla strony publicznej
  images       String[] @default([])      // Vercel Blob URLs (do 3 zdjęć)
  imageUrl     String?  @db.Text         // TYMCZASOWO - stare base64, usunąć po migracji
  hiddenMaintenanceItems   String[] @default([]) // wartości MaintenanceType ukryte per rower
  maintenanceIntervals     Json     @default("{}") // nadpisane interwały per typ: { "TIRE_PRESSURE": { "intervalKm": 400, "intervalDays": 21 } }

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parts            BikePart[]
  customParts      CustomPart[]
  services         ServiceEvent[]
  partReplacements PartReplacement[]
  comments         BikeComment[]
  likes            BikeLike[]
  maintenanceLogs        MaintenanceLog[]
  customMaintenanceTasks CustomMaintenanceTask[]
  customMaintenanceLogs  CustomMaintenanceLog[]

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isPublic, type])
}

model BikePart {
  id     String   @id @default(cuid())
  bikeId String
  type   PartType

  wearKm     Int @default(0)
  expectedKm Int
  isInstalled Boolean @default(true) // Czy część jest zamontowana (dla akcesoriów)

  // Nowe pola dla globalnego systemu produktów
  productId String? // Referencja do globalnego produktu
  installedAt DateTime? // Data montażu
  partSpecificData Json? // Specyficzne dane dla tej instancji części
  images       String[] @default([]) // Vercel Blob URLs (do 3 zdjęć)

  bike         Bike              @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  product      PartProduct?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  replacements PartReplacement[]
  reviews      PartReview[]

  createdAt DateTime @default(now())

  @@unique([bikeId, type])
  @@index([bikeId])
  @@index([productId])
}

// Customowe części użytkownika (poza predefiniowaną listą PartType)
model CustomPart {
  id         String    @id @default(cuid())
  bikeId     String
  name       String    // Nazwa zdefiniowana przez użytkownika, np. "Pancerz"
  category   String    // Klucz kategorii: "frame", "drivetrain", "brakes", "wheels", "cockpit", "accessories"

  wearKm     Int       @default(0)
  expectedKm Int       @default(0) // 0 = brak limitu

  brand       String?
  model       String?
  installedAt DateTime?

  bike Bike @relation(fields: [bikeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([bikeId])
}

// 👇 NOWY MODEL - Historia wymian
model PartReplacement {
  id     String   @id @default(cuid())
  bikeId String
  partId String

  partType  PartType
  productId String? // Snapshot productId
  brand     String?
  model     String?
  notes     String?

  kmAtReplacement Int // Przebieg roweru w momencie wymiany
  kmUsed          Int // Ile km przejechał komponent (wearKm w momencie wymiany)

  bike    Bike         @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  part    BikePart     @relation(fields: [partId], references: [id], onDelete: Cascade)
  product PartProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([bikeId, partType])
  @@index([partId])
  @@index([productId])
}

// Części przechowywane w garażu użytkownika (zdjęte z roweru, ale zachowane)
model StoredPart {
  id               String    @id @default(cuid())
  userId           String
  partType         PartType
  brand            String?
  model            String?
  wearKm           Int       @default(0)
  expectedKm       Int       @default(0)
  productId        String?
  partSpecificData Json?
  notes            String?
  fromBikeId       String?   // Informacyjnie: skąd pochodzi część
  removedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product PartProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
}

// Części customowe przechowywane w garażu (zdjęte przy wymianie)
model CustomStoredPart {
  id          String    @id @default(cuid())
  userId      String
  name        String    // Nazwa zdefiniowana przez użytkownika
  category    String    // Klucz kategorii: "frame", "drivetrain", etc.
  brand       String?
  model       String?
  wearKm      Int       @default(0)
  expectedKm  Int       @default(0)
  installedAt DateTime?
  notes            String?
  inGarage         Boolean   @default(true)
  fromBikeId       String?
  fromCustomPartId String?  // Link do oryginalnej CustomPart (dla historii)
  removedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([fromCustomPartId])
}

// Globalna baza produktów (community-driven)
model PartProduct {
  id   String   @id @default(cuid())
  type PartType

  brand String
  model String

  // Metadane produktu (opcjonalne - rozbudowa w przyszłości)
  description   String?  @db.Text
  officialPrice Decimal? @db.Decimal(10, 2)
  images        String[] @default([]) // Vercel Blob URLs (do 3 zdjęć)

  // Agregowane statystyki (denormalizowane dla wydajności)
  averageRating      Float? @default(0)
  totalReviews       Int    @default(0)
  averageKmLifespan  Int?   @default(0)
  totalInstallations Int    @default(0)

  // Specyfikacja produktu (różna dla różnych typów)
  specifications Json? // { width: 28, tubeless: true, ... }

  bikeParts           BikePart[]
  reviews             PartReview[]
  serviceEvents       ServiceEvent[]
  partReplacements    PartReplacement[]
  storedParts         StoredPart[]
  bikeProductDefaults BikeProductDefaultPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, brand, model])
  @@index([type, averageRating])
  @@index([brand])
}

// Opinie użytkowników o produktach (części i smary)
model PartReview {
  id             String  @id @default(cuid())
  userId         String
  partId         String? // Opcjonalne - dla opinii o częściach
  serviceEventId String? // Opcjonalne - dla opinii o smarach
  productId      String

  rating     Int     // 1-5
  reviewText String? @db.Text

  // Kontekst użytkowania
  kmAtReview Int      // Przebieg w momencie dodania opinii
  kmUsed     Int      // Ile km przejechał komponent / km od smarowania
  bikeType   BikeType // Typ roweru (kontekst)

  // Pros/Cons
  pros String[] @default([])
  cons String[] @default([])

  // Zdjęcia
  images String[] @default([])

  // Weryfikacja
  verified Boolean @default(true) // true jeśli linked do rzeczywistego BikePart/ServiceEvent

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  part         BikePart?     @relation(fields: [partId], references: [id], onDelete: Cascade)
  serviceEvent ServiceEvent? @relation(fields: [serviceEventId], references: [id], onDelete: Cascade)
  product      PartProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  likes        ReviewLike[]
  reports      ReviewReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, partId])
  @@unique([userId, serviceEventId])
  @@index([productId, rating])
  @@index([userId])
}

model ServiceEvent {
  id       String      @id @default(cuid())
  bikeId   String
  type     ServiceType
  kmAtTime Int

  lubricantBrand     String?
  lubricantProductId String?
  notes              String?

  bike             Bike         @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  lubricantProduct PartProduct? @relation(fields: [lubricantProductId], references: [id], onDelete: SetNull)
  reviews          PartReview[]

  createdAt DateTime @default(now())

  @@index([bikeId, type, createdAt])
  @@index([lubricantProductId])
}

// Globalna baza modeli rowerów (community-driven)
model BikeProduct {
  id       String   @id @default(cuid())
  bikeType BikeType

  brand String // np. "Cannondale", "Trek", "Specialized"
  model String // np. "Topstone Carbon LTD Di2", "Domane SL 7"

  // Przyszłościowo: specyfikacja części dla tego modelu
  specifications Json? // { "crankset": "Shimano GRX 820, 48/31", "bb": "Shimano BSA 68", ... }

  // Metadane (opcjonalne)
  description      String? @db.Text
  officialImageUrl String?
  year             Int? // rok modelowy
  isElectric       Boolean @default(false)
  isPublic         Boolean @default(true) // Widoczny w katalogu publicznym

  defaultParts BikeProductDefaultPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bikeType, brand, model])
  @@index([brand])
  @@index([bikeType])
}

// Domyślne części dla modelu roweru (specyfikacja fabryczna)
model BikeProductDefaultPart {
  id            String   @id @default(cuid())
  bikeProductId String
  partProductId String
  partType      PartType
  expectedKm    Int      // Może nadpisać domyślny expectedKm dla tego roweru

  bikeProduct BikeProduct @relation(fields: [bikeProductId], references: [id], onDelete: Cascade)
  partProduct PartProduct @relation(fields: [partProductId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([bikeProductId, partType])
  @@index([bikeProductId])
  @@index([partProductId])
}

enum NotificationType {
  PART_WORN
  PART_NEAR_WORN
  SERVICE_DUE
  EMAIL_MISSING
  SYSTEM
  NEW_COMMENT    // Ktoś skomentował Twój rower
  COMMENT_REPLY  // Ktoś odpowiedział na Twój komentarz
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

model Notification {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  title   String
  message String

  bikeId    String?
  partId    String?
  commentId String?  // Referencja do komentarza (dla notyfikacji społecznościowych)

  status NotificationStatus @default(UNREAD)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ========== Polubienia rowerów ==========

model BikeLike {
  id     String @id @default(cuid())
  bikeId String
  userId String

  bike Bike @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([bikeId, userId])
  @@index([bikeId])
  @@index([userId])
}

// ========== Funkcje społecznościowe ==========

enum CommentType {
  GENERAL    // Ogólny komentarz
  SUGGESTION // Propozycja ulepszenia
  QUESTION   // Pytanie
}

model BikeComment {
  id       String      @id @default(cuid())
  bikeId   String
  userId   String
  parentId String?     // Dla odpowiedzi (nullable = komentarz główny)
  content  String      @db.Text
  type     CommentType @default(GENERAL)
  isHidden Boolean     @default(false) // Soft-delete / ukryty przez moderację

  bike    Bike          @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  BikeComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies BikeComment[] @relation("CommentReplies")
  reports CommentReport[]
  likes   CommentLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bikeId, createdAt])
  @@index([userId])
  @@index([parentId])
}

enum ReportReason {
  SPAM
  OFFENSIVE
  IRRELEVANT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model CommentReport {
  id        String       @id @default(cuid())
  commentId String
  userId    String       // Kto zgłosił
  reason    ReportReason
  details   String?      @db.Text
  status    ReportStatus @default(PENDING)

  comment BikeComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([commentId, userId]) // Jedno zgłoszenie per użytkownik per komentarz
  @@index([status])
}

model ReviewReport {
  id       String       @id @default(cuid())
  reviewId String
  userId   String
  reason   ReportReason
  details  String?      @db.Text
  status   ReportStatus @default(PENDING)

  review PartReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([status])
}

// ========== Weryfikacja email ==========

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ========== Polubienia komentarzy ==========

model CommentLike {
  id        String @id @default(cuid())
  commentId String
  userId    String

  comment BikeComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

// ========== Polubienia opinii o produktach ==========

model ReviewLike {
  id       String @id @default(cuid())
  reviewId String
  userId   String

  review PartReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}